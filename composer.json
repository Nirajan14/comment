{
    "name": "nirajan/comment",
    "description": "A Laravel package for handling comments",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nirajan\\Comment\\": "src/"
        },
        "files": [
            "src/Helpers/helper.php"
        ]
    },
    "authors": [
        {
            "name": "Nirajan Chaudhary",
            "email": "nirajanch011@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Nirajan\\Comment\\CommentServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^7.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}